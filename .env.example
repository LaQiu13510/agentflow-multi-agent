# AgentFlow environment example
# Copy to .env for local runs, or keep using ../smartkb-rag/.env through SMARTKB_PROJECT_DIR.

SMARTKB_PROJECT_DIR=../smartkb-rag
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
ZHIPUAI_API_KEY=your_zhipu_key
DASHSCOPE_API_KEY=your_dashscope_key
DB_URL=your_postgresql_connection_string
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
COLLECTION_NAME=my_rag_collection
AGENTFLOW_MEMORY_TABLE=agentflow_memories
AGENTFLOW_TOP_K=4
